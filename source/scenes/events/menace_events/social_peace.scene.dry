title: 사회적 안정
subtitle: 소요와 불안이 잦아들었습니다.
new-page: true
view-if: labor_unrest <= 30 and rural_unrest <= 30 and soldier_unrest <= 30 and crime <= 50 and not in_civil_war
max-visits: 1
on-arrival: social_peace_timer += 200; workers_m += 8 if m_in_exco or m_in_gov; workers_sr += 8 if sr_in_exco or sr_in_gov; soldiers_m += 8 if m_in_exco or m_in_gov; soldiers_sr += 8 if sr_in_exco or sr_in_gov; workers_k += 6; workers_b += 6 if b_in_gov; soldiers_b += 6 if b_in_gov; prov_gov_legitimacy += 30; social_peace = 1
achievement: law_and_order
tags: event

