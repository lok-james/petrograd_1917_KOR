title: 선거 시뮬레이션
set-jump: post_election


- @1917_1: 제헌의회 (1917년 3월 당시 지지율)
- @1917_11: 제헌의회 (1917년 11월)
- @ps_1917_3: 페트로그라드 소비에트 (1917년 3월)
- @ps_1917_8: 페트로그라드 소비에트 (1917년 8월)

@1917_1
on-arrival: {!
Q.election_type = "ca";
Q.workers = 20; // 
Q.middle = 8; //
Q.peasants = 60; // 
Q.soldiers = 8; //
Q.underclass = 6;
Q.elites = 2;

