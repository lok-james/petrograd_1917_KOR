[? if player_party == "b": 불만도: [+ leninist_dissent : dissent +], 세력: [+ leninist_strength : strength_2 +]?]

[? if player_party == "m": 사회애국주의파 ?]
[? if player_party == "m": 불만도: [+ social_patriot_dissent : dissent +], 세력: [+ social_patriot_strength : strength_2 +]?]

[? if player_party == "m": 혁명적 방위주의파 ?]
[? if player_party == "m": 불만도: [+ defensist_dissent : dissent +], 세력: [+ defensist_strength : strength_2 +]?]

